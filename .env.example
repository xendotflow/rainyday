PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-long-random-string
SALT_ROUNDS=12

# username that gets admin controls — set this before registering
ADMIN_USERNAME=admin

# in-game multiplayer (easyrpg-player-server)
# rainyday auto-starts the binary if it exists at the path below
# EASYRPG_MP_AUTO_START=false
# EASYRPG_MP_BIND=127.0.0.1:6500
# EASYRPG_MP_UPSTREAM=ws://127.0.0.1:6500
# EASYRPG_MP_BINARY=EasyRPG-Player-Monoko/build/easyrpg-player-server

# only needed when NODE_ENV=production (direct https, no nginx)
# SSL_KEY_PATH=/path/to/privkey.pem
# SSL_CERT_PATH=/path/to/fullchain.pem
